# Runtime environment selector (required)
NEXT_PUBLIC_APP_ENV=development

# API base URL by environment (required for active NEXT_PUBLIC_APP_ENV)
NEXT_PUBLIC_BIM_SCORING_API_BASE_URL_DEVELOPMENT=
NEXT_PUBLIC_BIM_SCORING_API_BASE_URL_STAGING=
NEXT_PUBLIC_BIM_SCORING_API_BASE_URL_PRODUCTION=

# Optional backward-compatible API URL keys (use only if needed)
NEXT_PUBLIC_API_BASE_URL_DEVELOPMENT=
NEXT_PUBLIC_API_BASE_URL_STAGING=
NEXT_PUBLIC_API_BASE_URL_PRODUCTION=

# Feature flag override (optional)
# default: false in production/staging; development is configurable via this override.
NEXT_PUBLIC_FEATURE_REAL_BACKEND_WRITE=false

# Supabase Auth (required for sign in / sign up / Google OAuth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_AUTH_REDIRECT_URL=

# Employee-number credential mode (optional)
NEXT_PUBLIC_AUTH_PASSWORD_EMAIL_DOMAIN=pegawai.example.com

# Manual role switch override (for dev emergency only, default disabled)
NEXT_PUBLIC_AUTH_ALLOW_ROLE_SWITCH=false
